generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUMS
//////////////////////

enum TournamentState {
  SCHEDULED
  ROUNDROBIN
  PLAYOFFS
  SEMIFINALS
  FINALS
  FINISHED
}

enum MemberRole {
  ADMIN
  MANAGER
  CAPTAIN
  EDITOR
  DEFAULT
}

enum TeamState {
  ACTIVE
  ELIMINATED
}

enum MatchType {
  ROUNDROBIN
  PLAYINS
  PLAYOFFS
  SEMIFINALS
  FINALS
  PRACTICE
}

enum MatchStatus {
  SCHEDULED
  ACTIVE
  PENDINGREGISTERS
  FINISHED
}

enum MapType {
  CONTROL
  HYBRID
  PAYLOAD
  PUSH
  FLASHPOINT
}

enum HeroRole {
  TANK
  DPS
  SUPPORT
}

enum DraftActionType {
  BAN
  PICK
  SKIP
}

enum phase {
  STARTING
  MAPPICKING
  BAN
  ENDMAP
  FINISHED

}


//////////////////////
// MODELS
//////////////////////

model Tournament {
  id        Int             @id @default(autoincrement())
  name      String
  startDate DateTime
  state     TournamentState @default(SCHEDULED)

  teams   Team[]
  matches Match[]
}

model Member {
  id           Int        @id @default(autoincrement())
  nickname     String
  user         String     @unique
  passwordHash String
  role         MemberRole @default(DEFAULT)
  profilePic   String?
  rank         Int        @default(0)

  teamId Int?
  team   Team? @relation(fields: [teamId], references: [id])
  playerStats PlayerStat[]
}

model Team {
  id     Int       @id @default(autoincrement())
  name   String
  logo   String?
  roster String?
  state  TeamState @default(ACTIVE)

  victories Int @default(0)
  mapWins   Int @default(0)
  mapLoses  Int @default(0)

  tournamentId Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id])

  members Member[]

  matchesA     Match[]       @relation("TeamA")
  matchesB     Match[]       @relation("TeamB")
  draftActions DraftAction[]
}

model Match {
  id        Int         @id @default(autoincrement())
  type      MatchType
  bestOf    Int
  status    MatchStatus @default(SCHEDULED)
  startDate DateTime?

  tournamentId Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id])

  teamAId Int
  teamA   Team @relation("TeamA", fields: [teamAId], references: [id])

  teamBId Int
  teamB   Team @relation("TeamB", fields: [teamBId], references: [id])

  teamAready Int @default(0)
  teamBready Int @default(0)

  pointsTeamA Int @default(0)
  pointsTeamB Int @default(0)

  mapWinsTeamA Int @default(0)
  mapWinsTeamB Int @default(0)

  gameNumber Int @default(0)
  semanas Int @default(1)
  title  String?
  mapsAllowedByRound Json?
  mapResults Json?

  allowedMaps Map[] @relation("AllowedMaps")
  
  draft DraftTable?
}

model News {
  id Int @id @default(autoincrement())
  title String
  content String
  imageUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DraftTable {
  id Int @id @default(autoincrement())

  matchId Int   @unique
  match   Match @relation(fields: [matchId], references: [id])

  currentTurnTeamId Int?

  phase        String
  phaseStartedAt DateTime @default(now())
  actions      DraftAction[]
  bannedHeroes Json
  pickedMaps   Json

  currentMapId Int?
}

model DraftAction {
  id Int @id @default(autoincrement())

  draftId Int
  draft   DraftTable @relation(fields: [draftId], references: [id])

  teamId Int
  team   Team @relation(fields: [teamId], references: [id])

  action DraftActionType
  value  Int? // heroId o mapId (null si skip)
  gameNumber Int @default(1)

  order Int // turno (1,2,3,...)

  createdAt DateTime @default(now())
}

model Map {
  id          Int     @id @default(autoincrement())
  type        MapType
  description String
  imgPath     String

  matches Match[] @relation("AllowedMaps")
}

model Hero {
  id      Int      @id @default(autoincrement())
  name    String?
  role    HeroRole
  imgPath String
}

model PlayerStat {
  id Int @id @default(autoincrement())

  damage     Int
  healing    Int
  mitigation Int
  kills      Int
  assists    Int
  deaths     Int
  gameDuration Int
  waitTime     Int @default(0)
  initialTime  Int @default(0)
  extraRounds  Int @default(0)
  effectiveDuration Int @default(1)

  damagePer10     Float @default(0)
  healingPer10    Float @default(0)
  mitigationPer10 Float @default(0)
  killsPer10      Float @default(0)
  assistsPer10    Float @default(0)
  deathsPer10     Float @default(0)

  mapType MapType
  role    HeroRole

  userId Int
  user   Member @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}
